# Clé API Giphy - Obtenir sur https://developers.giphy.com/
GIPHY_API_KEY=your_giphy_api_key_here

# ID de l'extension Chrome (pour sécurité CORS)
# Mettre "soon" pour autoriser toutes les origines (développement/test)
EXTENSION_ID=soon

# Port pour dev local (optionnel)
PORT=3000

# Lemon Squeezy Configuration
# API Key: Settings → API → Create new token
LEMONSQUEEZY_API_KEY=lsq_...

# Store ID: Found in your Lemon Squeezy dashboard URL
LEMONSQUEEZY_STORE_ID=...

# Variant ID: Products → Your Product → Variants → Copy Variant ID
# Note: Users will use direct Lemon Squeezy checkout links
LEMONSQUEEZY_VARIANT_ID=...